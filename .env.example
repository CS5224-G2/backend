# Copy this file to .env

# Environment: "dev" or "prod"
ENVIRONMENT=dev

# --- Databases ---

# Places DB (PostgreSQL + PostGIS)
# Dev:  use your local pgAdmin password
# Prod: RDS endpoint (set via AWS Secrets Manager / ECS task env vars)
PLACES_DB_URL=postgresql+asyncpg://postgres:yourpassword@localhost:5432/CycleLink

# MongoDB (Atlas / Self-Hosted)
MONGODB_URL=mongodb://localhost:27017

# --- Auth ---
# Generate with: openssl rand -hex 32
SECRET_KEY=changeme

# --- CORS ---
# Comma-separated, e.g. http://localhost:3000,http://cyclelink.com
ALLOWED_ORIGINS=http://localhost:3000

# --- GPX export ---
# Mostly as a convenience for debugging. 
# You can visualize gpx with https://gpx.studio/app or similar tools.
# Set to true to save generated GPX files to the saved_gpx/ folder.
# Each request writes a unique file (route_<uuid>.gpx).
SAVE_GPX=true

# --- External service base URLs ---
# Add as services come online
# SERVICE_URLS={"route_recommender": "http://localhost:8001", "NEA_service": "http://nea_service:8002"}
SERVICE_URLS={}
