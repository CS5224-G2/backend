# Copy this file to .env

# Environment: "dev" or "prod"
ENVIRONMENT=dev

# --- Databases ---

# Places DB (PostgreSQL + PostGIS)
# Dev:  use your local pgAdmin password
# Prod: RDS endpoint (set via AWS Secrets Manager / ECS task env vars)
PLACES_DB_URL=postgresql+asyncpg://postgres:yourpassword@localhost:5432/CycleLink

# --- Auth ---
# Generate with: openssl rand -hex 32
SECRET_KEY=changeme

# --- CORS ---
# Comma-separated, e.g. http://localhost:3000,http://cyclelink.com
ALLOWED_ORIGINS=http://localhost:3000

# --- External service base URLs ---
# Add as services come online
# SERVICE_URLS={"route_recommender": "http://localhost:8001", "NEA_service": "http://nea_service:8002"}
SERVICE_URLS={}
